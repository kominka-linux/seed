tmpdir="${TMPDIR:-/tmp}/seed-awk-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

printf 'alpha beta\n' >"$tmpdir/input"

awk -e 'BEGIN { print "begin" } { print $2 } END { print "end" }' "$tmpdir/input" >"$tmpdir/actual"
printf 'begin\nbeta\nend\n' >"$tmpdir/expected"

diff -u "$tmpdir/expected" "$tmpdir/actual"
