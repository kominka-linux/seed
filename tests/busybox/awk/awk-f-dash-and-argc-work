tmpdir="${TMPDIR:-/tmp}/seed-awk-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

printf 'do re mi\n' >"$tmpdir/input"
printf '{print $2; print ARGC;}\n' >"$tmpdir/script.awk"

awk -f - "$tmpdir/input" <"$tmpdir/script.awk" >"$tmpdir/actual"
printf 're\n2\n' >"$tmpdir/expected"

diff -u "$tmpdir/expected" "$tmpdir/actual"
