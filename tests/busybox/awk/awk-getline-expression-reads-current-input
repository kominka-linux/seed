tmpdir="${TMPDIR:-/tmp}/seed-awk-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

cat >"$tmpdir/script.awk" <<'EOF'
{ status = getline nextline; print status, nextline, NR, FNR, $0 }
EOF
printf 'one\ntwo\nthree\n' >"$tmpdir/input"

awk -f "$tmpdir/script.awk" "$tmpdir/input" >"$tmpdir/actual"
cat >"$tmpdir/expected" <<'EOF'
1 two 2 2 one
0 two 3 3 three
EOF

diff -u "$tmpdir/expected" "$tmpdir/actual"
