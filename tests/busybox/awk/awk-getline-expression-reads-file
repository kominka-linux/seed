tmpdir="${TMPDIR:-/tmp}/seed-awk-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

cat >"$tmpdir/script.awk" <<EOF
BEGIN {
    status = getline line < "$tmpdir/input"
    print status, line
    status = getline line < "$tmpdir/input"
    print status, line
    status = getline line < "$tmpdir/input"
    print status, line
}
EOF
printf 'aa\nbb\n' >"$tmpdir/input"

awk -f "$tmpdir/script.awk" >"$tmpdir/actual"
cat >"$tmpdir/expected" <<'EOF'
1 aa
1 bb
0 bb
EOF

diff -u "$tmpdir/expected" "$tmpdir/actual"
