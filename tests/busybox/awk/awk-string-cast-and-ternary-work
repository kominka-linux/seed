tmpdir="${TMPDIR:-/tmp}/seed-awk-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

cat >"$tmpdir/script.awk" <<'EOF'
function b(tmp) {
  tmp = 0;
  print "" tmp;
  return tmp;
}
function c(tmpc) {
  tmpc = b(); return tmpc;
}
BEGIN {
  print (c() ? "string" : "number");
}
EOF

awk -f "$tmpdir/script.awk" >"$tmpdir/actual"
printf '0\nnumber\n' >"$tmpdir/expected"

diff -u "$tmpdir/expected" "$tmpdir/actual"
