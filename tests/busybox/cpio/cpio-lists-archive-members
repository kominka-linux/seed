tmpdir="${TMPDIR:-/tmp}/seed-cpio-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir/src"

printf 'a\n' >"$tmpdir/src/a"
printf 'b\n' >"$tmpdir/src/b"

find "$tmpdir/src" -print | busybox cpio -o -H newc >"$tmpdir/archive.cpio"
busybox cpio -t <"$tmpdir/archive.cpio" >"$tmpdir/list"

canonical_src=$(printf '%s\n' "$tmpdir/src" | sed 's://*:/:g')
stripped_src=${canonical_src#/}
grep -Fx "$stripped_src" "$tmpdir/list"
grep -Fx "$stripped_src/a" "$tmpdir/list"
grep -Fx "$stripped_src/b" "$tmpdir/list"
