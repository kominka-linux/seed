tmpdir="${TMPDIR:-/tmp}/seed-delgroup-primary-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir/etc"

cat >"$tmpdir/etc/passwd" <<'EOF'
alice:x:1000:1005::/home/alice:/bin/sh
EOF

cat >"$tmpdir/etc/group" <<'EOF'
staff:x:1005:
EOF

if SEED_ETC_DIR="$tmpdir/etc" busybox delgroup staff >/dev/null 2>stderr; then
	exit 1
fi

grep "still has 'alice' as their primary group" stderr
