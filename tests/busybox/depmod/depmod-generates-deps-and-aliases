modules="$PWD/lib/modules/1.0"
mkdir -p "$modules/kernel/net"

printf '\0license=GPL\0' > "$modules/kernel/net/helper.ko"
printf '\0depends=helper\0alias=test:*\0license=GPL\0' > "$modules/kernel/net/driver.ko"

SEED_MODULES_DIR="$modules" busybox depmod
SEED_MODULES_DIR="$modules" busybox depmod -n > out

grep '^kernel/net/helper\.ko:$' "$modules/modules.dep"
grep '^kernel/net/driver\.ko: kernel/net/helper\.ko$' "$modules/modules.dep"
grep '^alias test:\* driver$' "$modules/modules.alias"
grep '^kernel/net/driver\.ko: kernel/net/helper\.ko$' out

