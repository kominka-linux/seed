state=$PWD/net.state
cat > "$state" <<'EOF'
iface	1	eth0	67	1500	02:00:00:00:00:01	10	1	20	2
addr	eth0	inet	10.0.0.2	24		10.0.0.255
EOF

SEED_NET_STATE="$state" busybox ifconfig > out

grep 'eth0  Link encap:Ethernet  HWaddr 02:00:00:00:00:01' out
grep 'inet addr:10.0.0.2  Mask:255.255.255.0  Bcast:10.0.0.255' out
grep 'UP BROADCAST RUNNING  MTU:1500' out
