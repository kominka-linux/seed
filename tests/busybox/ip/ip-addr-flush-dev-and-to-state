state=$(mktemp "${TMPDIR:-/tmp}/seed-net-state.XXXXXX")
trap 'rm -f "$state"' EXIT HUP INT TERM

cat >"$state" <<'EOF'
iface	2	eth0	67	1500	0	1000	02:00:00:00:00:01	0	0	0	0
addr	eth0	inet	10.0.0.2	24		10.0.0.255
addr	eth0	inet	10.0.1.2	24		10.0.1.255
addr	eth0	inet6	2001:db8::2	64		
EOF

SEED_NET_STATE="$state" busybox ip addr flush dev eth0 to 10.0.0.0/24
SEED_NET_STATE="$state" busybox ip addr show dev eth0 >out

if grep 'inet 10.0.0.2/24' out >/dev/null; then
	echo "ip unexpectedly left flushed IPv4 prefix behind" >&2
	exit 1
fi
grep 'inet 10.0.1.2/24' out
grep 'inet6 2001:db8::2/64' out
