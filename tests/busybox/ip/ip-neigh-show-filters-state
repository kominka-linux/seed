state=$(mktemp "${TMPDIR:-/tmp}/seed-net-state.XXXXXX")
trap 'rm -f "$state"' EXIT HUP INT TERM

cat >"$state" <<'EOF'
neigh	inet	10.0.0.1	eth0	02:00:00:00:00:01	4
neigh	inet	10.1.0.1	eth0	02:00:00:00:00:02	2
neigh	inet6	fe80::1	eth0	02:00:00:00:00:03	4
EOF

SEED_NET_STATE="$state" busybox ip neigh show to 10.0.0.0/24 dev eth0 nud stale >out

grep '^10.0.0.1 dev eth0 lladdr 02:00:00:00:00:01 STALE$' out
if [ "$(wc -l <out)" -ne 1 ]; then
	echo "unexpected extra ip neigh lines" >&2
	exit 1
fi
