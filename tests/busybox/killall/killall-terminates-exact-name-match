cat > match-killall-target <<'EOF'
#!/bin/sh
sleep 30
EOF
chmod +x match-killall-target
./match-killall-target &
child=$!
if ! busybox killall match-killall-target; then
	kill "$child" 2>/dev/null || true
	wait "$child" 2>/dev/null || true
	exit 1
fi
if wait "$child"; then
	exit 1
else
	status=$?
fi
test "$status" -eq 143 || exit 1
