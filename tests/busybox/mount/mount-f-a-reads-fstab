tmpdir="${TMPDIR:-/tmp}/seed-mount-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

cat >"$tmpdir/fstab" <<'EOF'
tmpfs /run tmpfs defaults 0 0
/dev/data /data xfs noauto 0 0
EOF

SEED_FSTAB="$tmpdir/fstab" busybox mount -f -a -v -t tmpfs 2>"$tmpdir/stderr"
grep '^tmpfs on /run type tmpfs (defaults)$' "$tmpdir/stderr"
