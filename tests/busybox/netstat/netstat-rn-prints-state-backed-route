state=$PWD/net.state
cat >"$state" <<'EOF'
iface	2	eth0	3	1500	02:00:00:00:00:01	0	0	0	0
route	inet	0.0.0.0	0	10.0.0.1	eth0
EOF

SEED_NET_STATE="$state" busybox netstat -rn >out

grep '^Kernel IP routing table$' out
grep '^Destination[[:space:]]\+Gateway[[:space:]]\+Genmask[[:space:]]\+Flags[[:space:]]\+Iface$' out
grep '0.0.0.0[[:space:]]\+10.0.0.1[[:space:]]\+0.0.0.0[[:space:]]\+UG[[:space:]]\+eth0' out
