tmpdir="${TMPDIR:-/tmp}/seed-ntpd-auth-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

port="$(python3 - <<'PY'
import socket
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
s.bind(("127.0.0.1", 0))
print(s.getsockname()[1])
s.close()
PY
)"

cat >"$tmpdir/ntp.keys" <<'EOF'
7 MD5 secret
EOF

python3 - <<'PY' "$port" &
import socket
import struct
import sys
import hashlib

port = int(sys.argv[1])
key = b"secret"
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
s.bind(("127.0.0.1", port))
data, addr = s.recvfrom(512)
assert len(data) == 68, len(data)
assert struct.unpack("!I", data[48:52])[0] == 7
assert data[52:] == hashlib.md5(key + data[:48]).digest()
orig = data[40:48]
pkt = bytearray(48)
pkt[0] = (4 << 3) | 4
pkt[1] = 2
pkt[2] = 6
pkt[3] = 236
pkt[12:16] = b"AUTH"
pkt[24:32] = orig
pkt[32:40] = struct.pack("!II", 2208989800, 0)
pkt[40:48] = struct.pack("!II", 2208989801, 0)
pkt.extend(struct.pack("!I", 7))
pkt.extend(hashlib.md5(key + pkt[:48]).digest())
s.sendto(pkt, addr)
s.close()
PY
server_pid=$!
trap 'kill "$server_pid" 2>/dev/null || true; rm -rf "$tmpdir"' EXIT

sleep 0.1
SEED_NTP_PORT="$port" busybox ntpd -q -w -k "$tmpdir/ntp.keys" -p keyno:7:127.0.0.1
