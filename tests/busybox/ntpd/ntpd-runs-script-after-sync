tmpdir="${TMPDIR:-/tmp}/seed-ntpd-script-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

port="$(python3 - <<'PY'
import socket
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
s.bind(("127.0.0.1", 0))
print(s.getsockname()[1])
s.close()
PY
)"

cat >"$tmpdir/script" <<'EOF'
#!/bin/sh
printf '%s:%s\n' "$stratum" "$server" > "$1"
EOF
chmod +x "$tmpdir/script"

python3 - <<'PY' "$port" &
import socket
import struct
import sys

port = int(sys.argv[1])
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
s.bind(("127.0.0.1", port))
data, addr = s.recvfrom(512)
orig = data[40:48]
pkt = bytearray(48)
pkt[0] = (4 << 3) | 4
pkt[1] = 4
pkt[2] = 6
pkt[3] = 236
pkt[12:16] = b"HOOK"
pkt[24:32] = orig
pkt[32:40] = struct.pack("!II", 2208989800, 0)
pkt[40:48] = struct.pack("!II", 2208989801, 0)
s.sendto(pkt, addr)
s.close()
PY
server_pid=$!
trap 'kill "$server_pid" 2>/dev/null || true; rm -rf "$tmpdir"' EXIT

sleep 0.1
SEED_NTP_PORT="$port" busybox ntpd -q -w -S "$tmpdir/script $tmpdir/out" -p 127.0.0.1
grep '^4:127.0.0.1:' "$tmpdir/out"
