tmpdir="${TMPDIR:-/tmp}/seed-passwd-delete-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir/etc"

cat >"$tmpdir/etc/passwd" <<'EOF'
alice:x:1000:1000::/home/alice:/bin/sh
EOF

cat >"$tmpdir/etc/shadow" <<'EOF'
alice:hash:20557:0:99999:7:::
EOF

SEED_ETC_DIR="$tmpdir/etc" busybox passwd -d alice
grep '^alice::' "$tmpdir/etc/shadow"
