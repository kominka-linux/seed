tmpdir="${TMPDIR:-/tmp}/seed-passwd-lock-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir/etc"

cat >"$tmpdir/etc/passwd" <<'EOF'
alice:x:1000:1000::/home/alice:/bin/sh
EOF

cat >"$tmpdir/etc/shadow" <<'EOF'
alice:hash:20557:0:99999:7:::
EOF

SEED_ETC_DIR="$tmpdir/etc" busybox passwd -l alice
grep '^alice:!hash:' "$tmpdir/etc/shadow"

SEED_ETC_DIR="$tmpdir/etc" busybox passwd -u alice
grep '^alice:hash:' "$tmpdir/etc/shadow"
