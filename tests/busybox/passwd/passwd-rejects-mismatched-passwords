tmpdir="${TMPDIR:-/tmp}/seed-passwd-mismatch-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir/etc"

cat >"$tmpdir/etc/passwd" <<'EOF'
alice:x:1000:1000::/home/alice:/bin/sh
EOF

cat >"$tmpdir/etc/shadow" <<'EOF'
alice:hash:20557:0:99999:7:::
EOF

if printf 'secret\nnope\n' | SEED_ETC_DIR="$tmpdir/etc" busybox passwd alice >/dev/null 2>stderr; then
	exit 1
fi

grep "password for alice is unchanged" stderr
grep '^alice:hash:' "$tmpdir/etc/shadow"
