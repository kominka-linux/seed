tmpdir="${TMPDIR:-/tmp}/seed-passwd-sha512-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir/etc"

cat >"$tmpdir/etc/passwd" <<'EOF'
alice:x:1000:1000::/home/alice:/bin/sh
EOF

printf 'secret\nsecret\n' | SEED_ETC_DIR="$tmpdir/etc" busybox passwd alice >/dev/null
grep '^alice:\$6\$' "$tmpdir/etc/shadow"
