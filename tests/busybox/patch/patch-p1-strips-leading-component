cat > input <<'EOF'
foo
bar
EOF

mkdir a b
cp input a/input
cp input b/input

cat > expected <<'EOF'
foo
baz
bar
EOF

cat > update.patch <<'EOF'
--- a/input
+++ b/input
@@ -1,2 +1,3 @@
 foo
+baz
 bar
EOF

busybox patch -p1 < update.patch > stdout 2> stderr
cmp expected input
grep "patching file input" stderr
