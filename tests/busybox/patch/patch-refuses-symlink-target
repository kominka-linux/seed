set -eu

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT HUP INT TERM

printf 'old\n' > "$tmpdir/real"
ln -s real "$tmpdir/link"
cat > "$tmpdir/update.patch" <<'EOF'
--- link
+++ link
@@ -1 +1 @@
-old
+new
EOF

if busybox patch -i "$tmpdir/update.patch" >/dev/null 2>&1; then
	exit 1
fi

test "$(cat "$tmpdir/real")" = "old"

