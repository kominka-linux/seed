cat > pidof-one <<'EOF'
#!/bin/sh
sleep 30 &
child=$!
trap 'kill "$child" 2>/dev/null || true; wait "$child" 2>/dev/null || true' EXIT TERM INT
wait "$child"
EOF
chmod +x pidof-one
./pidof-one &
pid1=$!
./pidof-one &
pid2=$!
trap 'kill "$pid1" "$pid2" 2>/dev/null || true; wait "$pid1" "$pid2" 2>/dev/null || true' EXIT

set -- $(busybox pidof -s pidof-one)
test $# -eq 1
test "$1" = "$pid1" || test "$1" = "$pid2"
