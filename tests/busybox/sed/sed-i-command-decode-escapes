tmpdir="${TMPDIR:-/tmp}/seed-sed-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

printf 'line1\n' >"$tmpdir/input"

sed "/1/i\\t\\rzero\\none\\\\ntwo\\\\\\nthree" "$tmpdir/input" >"$tmpdir/actual"
printf 't\rzero\none\\ntwo\\\nthree\nline1\n' >"$tmpdir/expected"

diff -u "$tmpdir/expected" "$tmpdir/actual"
