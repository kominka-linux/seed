tmpdir="${TMPDIR:-/tmp}/seed-sed-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

cat >"$tmpdir/input" <<'EOF'
one
skip
two
three
EOF

busybox sed -n -e '/skip/d' -e '/two/,$p' "$tmpdir/input" >"$tmpdir/actual"
cat >"$tmpdir/expected" <<'EOF'
two
three
EOF

diff -u "$tmpdir/expected" "$tmpdir/actual"
