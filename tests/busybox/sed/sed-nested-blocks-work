tmpdir="${TMPDIR:-/tmp}/seed-sed-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

printf 'qwe\nasd\nzxc\n' >"$tmpdir/input"

sed '/asd/ { p; /s/ { s/s/c/ }; p; q }' "$tmpdir/input" >"$tmpdir/actual"
cat >"$tmpdir/expected" <<'EOF'
qwe
asd
acd
acd
EOF

diff -u "$tmpdir/expected" "$tmpdir/actual"
