tmpdir="${TMPDIR:-/tmp}/seed-sed-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

printf 'one\ntwo\n' >"$tmpdir/input"
printf 'alpha\nbeta\n' >"$tmpdir/extra"

sed "/one/r $tmpdir/extra" "$tmpdir/input" >"$tmpdir/actual"
cat >"$tmpdir/expected" <<EOF
one
alpha
beta
two
EOF

diff -u "$tmpdir/expected" "$tmpdir/actual"
