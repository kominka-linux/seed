python3 - <<'PY'
import os
import pty
import subprocess
import termios

master, slave = pty.openpty()
path = os.ttyname(slave)
original = subprocess.check_output(["busybox", "stty", "-F", path, "-g"], text=True).strip()
subprocess.run(["busybox", "stty", "-F", path, "raw", "-echo"], check=True)
subprocess.run(["busybox", "stty", "-F", path, original], check=True)
attrs = termios.tcgetattr(slave)
assert attrs[3] & termios.ICANON
assert attrs[3] & termios.ECHO
os.close(master)
os.close(slave)
PY
