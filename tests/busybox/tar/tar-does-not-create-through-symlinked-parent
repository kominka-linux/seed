# FEATURE: CONFIG_FEATURE_TAR_CREATE

set -eu

tmpdir=$(mktemp -d)
trap 'rm -rf "$tmpdir"' EXIT HUP INT TERM

mkdir -p "$tmpdir/src/dir/sub" "$tmpdir/outside" "$tmpdir/dest"
printf 'data\n' >"$tmpdir/src/dir/sub/file"
(cd "$tmpdir/src" && tar cf "$tmpdir/archive.tar" dir/sub/file)
ln -s "$tmpdir/outside" "$tmpdir/dest/dir"

if busybox tar xf "$tmpdir/archive.tar" -C "$tmpdir/dest" >/dev/null 2>&1; then
	exit 1
fi

test ! -e "$tmpdir/outside/sub/file"

