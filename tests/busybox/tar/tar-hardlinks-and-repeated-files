# FEATURE: CONFIG_FEATURE_TAR_CREATE

set -eu
script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
. "$script_dir/testlib.sh"

setup_case() {
	: >input_hard1
	ln input_hard1 input_hard2
	mkdir input_dir
	: >input_dir/file
	chmod -R 644 *
	chmod 755 input_dir
}

setup_case
busybox tar cf test.tar input_dir/ input_hard1 input_hard2 input_hard1 input_dir/
busybox tar tvf test.tar | normalize_tar_listing >actual.list
rm -rf input_dir input_hard1 input_hard2
busybox tar xf test.tar
/bin/ls -l . input_dir/* | grep input_ | normalize_ls_listing >actual.extract

cat >expected.list <<'EOF'
input_dir/
input_dir/file
input_hard1
input_hard2 -> input_hard1
input_hard1 -> input_hard1
input_dir/
input_dir/file
EOF

cat >expected.extract <<'EOF'
-rw-r--r-- input_dir/file
drwxr-xr-x input_dir
-rw-r--r-- input_hard1
-rw-r--r-- input_hard2
EOF

diff -u expected.list actual.list
diff -u expected.extract actual.extract

chmod -R u+w .
rm -rf input_dir input_hard1 input_hard2 test.tar expected.list expected.extract actual.list actual.extract
