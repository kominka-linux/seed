# FEATURE: CONFIG_FEATURE_TAR_CREATE

set -eu
script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
. "$script_dir/testlib.sh"

setup_case() {
	: >input_hard1
	chmod 741 input_hard1
	ln input_hard1 input_hard2
	mkdir input_dir
	ln input_hard1 input_dir
	ln input_hard2 input_dir
	chmod 550 input_dir
}

run_case() {
	mode=$1
	setup_case
	case "$mode" in
		system)
			tar_bin='PATH=/usr/bin:/bin tar'
			;;
		busybox)
			tar_bin='busybox tar'
			;;
	esac
	sh -c "$tar_bin cf test.tar input_dir/input_hard* input_hard*"
	sh -c "$tar_bin tvf test.tar" | normalize_tar_listing >"$mode.list"
	chmod 770 input_dir
	rm -f input_hard1 input_hard2 input_dir/input_hard1 input_dir/input_hard2
	sh -c "$tar_bin xf test.tar"
	/bin/ls -l . input_dir/* | grep 'input.*hard' | normalize_ls_listing >"$mode.extract"
	chmod -R u+w .
	rm -rf input_dir input_hard1 input_hard2 test.tar
}

mkdir system busybox
(
	cd system || exit 1
	run_case system
)
(
	cd busybox || exit 1
	run_case busybox
)

diff -u system/system.list busybox/busybox.list
diff -u system/system.extract busybox/busybox.extract
