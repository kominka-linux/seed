# FEATURE: CONFIG_FEATURE_TAR_CREATE

set -eu
script_dir=$(CDPATH= cd -- "$(dirname "$0")" && pwd)
. "$script_dir/testlib.sh"

setup_case() {
	mkdir input_dir
	: >input_dir/input_file
	chmod 550 input_dir
}

run_case() {
	mode=$1
	setup_case
	case "$mode" in
		system)
			tar_bin='PATH=/usr/bin:/bin tar'
			;;
		busybox)
			tar_bin='busybox tar'
			;;
	esac
	sh -c "$tar_bin cf test.tar input_dir"
	chmod 770 input_dir
	rm -rf input_dir
	sh -c "$tar_bin xf test.tar"
	/bin/ls -ld . input_dir input_dir/* | grep input_ | normalize_ls_listing >"$mode.extract"
	chmod -R u+w .
	rm -rf input_dir test.tar
}

mkdir system busybox
(
	cd system || exit 1
	run_case system
)
(
	cd busybox || exit 1
	run_case busybox
)

diff -u system/system.extract busybox/busybox.extract
