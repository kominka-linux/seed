tmpdir="${TMPDIR:-/tmp}/seed-udhcpc-release-$$"
trap 'rm -rf "$tmpdir"' EXIT
mkdir -p "$tmpdir"

server_port="$(python3 - <<'PY'
import socket
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
s.bind(("127.0.0.1", 0))
print(s.getsockname()[1])
s.close()
PY
)"

client_port="$(python3 - <<'PY'
import socket
s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
s.bind(("127.0.0.1", 0))
print(s.getsockname()[1])
s.close()
PY
)"

cat >"$tmpdir/udhcpd.conf" <<EOF
start 127.0.0.50
end 127.0.0.50
interface lo
server 127.0.0.1
option lease 30
lease_file $tmpdir/leases
EOF

cat >"$tmpdir/script" <<'EOF'
#!/bin/sh
:
EOF
chmod +x "$tmpdir/script"

SEED_DHCP_SERVER_PORT="$server_port" \
SEED_DHCP_CLIENT_PORT="$client_port" \
SEED_UDHCPD_MAX_PACKETS=5 \
busybox udhcpd -f "$tmpdir/udhcpd.conf" &
server_pid=$!
trap 'kill "$server_pid" 2>/dev/null || true; rm -rf "$tmpdir"' EXIT

sleep 0.1
SEED_DHCP_SERVER_ADDR="127.0.0.1:$server_port" \
SEED_DHCP_SERVER_PORT="$server_port" \
SEED_DHCP_CLIENT_PORT="$client_port" \
SEED_DHCP_CLIENT_MAC="02:00:00:00:00:01" \
busybox udhcpc -q -n -R -i lo -s "$tmpdir/script"

SEED_DHCP_SERVER_ADDR="127.0.0.1:$server_port" \
SEED_DHCP_SERVER_PORT="$server_port" \
SEED_DHCP_CLIENT_PORT="$client_port" \
SEED_DHCP_CLIENT_MAC="02:00:00:00:00:02" \
busybox udhcpc -q -n -i lo -s "$tmpdir/script"

wait "$server_pid"
grep '^127.0.0.50 02:00:00:00:00:02 ' "$tmpdir/leases"
