python3 - <<'PY'
import zipfile

with zipfile.ZipFile('archive.zip', 'w', compression=zipfile.ZIP_DEFLATED) as z:
    z.writestr('hello.txt', 'hello from zip\n')
    z.writestr('nested/world.txt', 'nested\n')
PY

mkdir out
busybox unzip -d out archive.zip >/dev/null

test -f out/hello.txt
test -f out/nested/world.txt
printf 'hello from zip\n' > expected-hello
printf 'nested\n' > expected-world
cmp expected-hello out/hello.txt
cmp expected-world out/nested/world.txt
